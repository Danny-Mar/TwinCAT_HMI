    ]
  },
  {
    "event": "%pp%Hmi::STATE::OFF%/pp%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('ProcessControlHome_UC_Button01_UC01');",
          "",
          "",
          "var _StateOff = TcHmi.Symbol.readEx('%pp%Hmi::STATE::OFF%/pp%');",
          "var _StateRun = TcHmi.Symbol.readEx('%pp%Hmi::STATE::RUN%/pp%');",
          "",
          "",
          "if (_StateOff or _StateRun) {",
