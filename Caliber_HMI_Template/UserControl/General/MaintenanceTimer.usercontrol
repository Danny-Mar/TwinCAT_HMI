<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "MaintTimerTextInput.onPressed",
    "actions": [
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%MaintTimer::Height%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/MeasurementValue",
          "value": 200.0
        },
        "asyncWait": true
      },
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%MaintTimer_Container02::Visibility%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/Visibility",
          "value": "Visible"
        },
        "asyncWait": true
      },
      {
        "objectType": "WriteToSymbol",
        "active": true,
        "symbolExpression": "%ctrl%MaintTimer_Container01::Visibility%/ctrl%",
        "value": {
          "objectType": "StaticValue",
          "valueType": "tchmi:framework#/definitions/Visibility",
          "value": "Collapsed"
        },
        "asyncWait": true
      },
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _time = TcHmi.Symbol.readEx('%pp%HMI::PT%/pp%');",
          "",
          "",
          "var output = [];",
          "var StringNumber = _time.toString();",
          "",
          "for (var i = 0, len = StringNumber.length; i < len; i += 1) {",
          "    output.push(+StringNumber.charAt(i));",
          "}",
          "",
          "var value_1_uc = TcHmi.Controls.get('value_1');",
          "var value_10_uc = TcHmi.Controls.get('value_10');",
          "var value_100_uc = TcHmi.Controls.get('value_100');",
          "var value_1000_uc = TcHmi.Controls.get('value_1000');",
          "",
          "\t",
          "switch(StringNumber.length) {",
          "  case 1:",
          "\tvalue_1000_uc.setText(0);",
          "\tvalue_100_uc.setText(0);",
          "\tvalue_10_uc.setText(0);",
          "\tvalue_1_uc.setText(StringNumber.charAt(0));",
          "    break;",
          "  case 2:",
          "\tvalue_1000_uc.setText(0);",
          "\tvalue_100_uc.setText(0);",
          "\tvalue_10_uc.setText(StringNumber.charAt(0));",
          "\tvalue_1_uc.setText(StringNumber.charAt(1));",
          "    break;",
          "  case 3:",
          "\tvalue_1000_uc.setText(0);",
          "\tvalue_100_uc.setText(StringNumber.charAt(0));",
          "\tvalue_10_uc.setText(StringNumber.charAt(1));",
          "\tvalue_1_uc.setText(StringNumber.charAt(2));",
          "    break;",
          "  case 4:",
          "\tvalue_1000_uc.setText(StringNumber.charAt(0));",
          "\tvalue_100_uc.setText(StringNumber.charAt(1));",
          "\tvalue_10_uc.setText(StringNumber.charAt(2));",
          "\tvalue_1_uc.setText(StringNumber.charAt(3));",
          "    break;",
          "  default:",
          "\tvalue_1000_uc.setText(0);",
          "\tvalue_100_uc.setText(0);",
          "\tvalue_10_uc.setText(0);",
          "\tvalue_1_uc.setText(0);",
          "} ",
          "",
          "",
          "/*",
          "if (isNaN(StringNumber.charAt(3))) {",
          "\tvalue_1000_uc.setText(0);",
          "}",
          "else {",
          "\tvalue_1_uc.setText(StringNumber.charAt(3));",
          "}",
          "",
          "if (isNaN(StringNumber.charAt(2))) {",
          "\tvalue_100_uc.setText(0);",
          "}",
          "else {",
          "\tvalue_10_uc.setText(StringNumber.charAt(2));",
          "}",
          "",
          "if (isNaN(StringNumber.charAt(1))) {",
          "\tvalue_10_uc.setText(0);",
          "}",
          "else {",
          "\tvalue_100_uc.setText(StringNumber.charAt(1));",
          "}*/",
          ""
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      },
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "//var childElement = document.getElementById('MaintTimer');",
          "",
          "//var parentElement = childElement.parentNode; ",
          "",
          "var childControl = TcHmi.Controls.get('MaintTimer');",
          "",
          "var parentControl = childControl.getParent();",
          "",
          "parentControl.setHeight(200);",
          "",
          "parentControl.setZindex(50);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  },
  {
    "event": "%pp%HMI::PT%/pp%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('MaintTimerTextInput');",
          "",
          "var _time = TcHmi.Symbol.readEx('%pp%HMI::PT%/pp%');",
          "",
          "var _timeString = '' + _time + 'h';",
          "",
          "_uc.setText(_timeString);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>
</div>
