  {
    "event": "minus_h_button.onPressed",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var value_1_uc = TcHmi.Controls.get('value_1');",
          "",
          "var _value_1 = parseInt(value_1_uc.getText());",
          "",
          "_value_1 = _value_1 - 1;",
          "if(_value_1 < 0)",
          "{",
          "\t_value_1 = 9;",
          "}",
          "",
          "value_1_uc.setText(_value_1);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>

