<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%pp%HMI::MINS_PASSED%/pp%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('MaintTimer_Textblock05');",
          "",
          "var _hours = TcHmi.Symbol.readEx('%pp%HMI::HOURS_PASSED%/pp%');",
          "var _minutes = TcHmi.Symbol.readEx('%pp%HMI::MINS_PASSED%/pp%');",
          "",
          "",
          "//var _temp = _hours.concat('h ');",
          "//_uc.setText(_temp.concat('m '));",
          "",
          "_uc.setText(\"\" + _hours + \"h \" + _minutes + \"m\");",
          "",
          "",
          "//_uc.setText(_hours);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  },
  {
    "event": "%pp%HMI::HOURS_PASSED%/pp%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('MaintTimer_Textblock05');",
          "",
          "var _hours = TcHmi.Symbol.readEx('%pp%HMI::HOURS_PASSED%/pp%');",
          "var _minutes = TcHmi.Symbol.readEx('%pp%HMI::MINS_PASSED%/pp%');",
          "",
          "",
          "_uc.setText(\"\" + _hours + \"h \" + _minutes + \"m\");"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>
