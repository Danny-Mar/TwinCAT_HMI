<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "Plus_h100_button.onPressed",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var value_100_uc = TcHmi.Controls.get('value_100');",
          "",
          "var _value_100 = parseInt(value_100_uc.getText());",
          "",
          "_value_100 = _value_100 + 1;",
          "if(_value_100 > 9)",
          "{",
          "\t_value_100 = 0;",
          "}",
          "",
          "value_100_uc.setText(_value_100);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>

