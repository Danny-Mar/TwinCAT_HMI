        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('TimerValue01');",
          "//var msVar_uc = TcHmi.Controls.get('ms_value');",
          "//var secVar_uc = TcHmi.Controls.get('sec_value');",
          "var _time = TcHmi.Symbol.readEx('%pp%TimeVar%/pp%');",
          "var _time = _time.replace('PT','');",
          "",
          "",
          "var _hourLoc = _time.indexOf('H');",
          "var _minuteLoc = _time.indexOf('M');",
          "var _secondLoc = _time.indexOf('S');",
          "var _second;",
          "var _minute;",
          "",
          "",
          "if (_hourLoc != -1) {",
          "var _hour = _time.slice(0, _hourLoc);",
          "} ",
          "",
          "if (_minuteLoc != -1) {",
          "\tif (_hourLoc != -1) {",
          "\t\t_minute = _time.slice(_hourLoc + 1, _minuteLoc);",
          "\t} else {",
          "\t\t_minute = _time.slice(0, _minuteLoc);",
          "\t}",
          "} ",
          "",
          "if (_secondLoc != -1) {",
          "\tif (_minuteLoc != -1) {",
          "\t\t_second = _time.slice(_minuteLoc + 1, _secondLoc);",
          "\t} else if (_hourLoc != -1) {",
          "\t\t_second = _time.slice(_hourLoc + 1, _secondLoc);",
          "\t} else {",
          "\t\t_second = _time.slice(0, _secondLoc);",
          "\t}",
          "}",
          "",
          "",
          "",
          "var _Secvalue = parseFloat(_second);",
          "",
          "if (isNaN(_Secvalue)) {",
          "_Secvalue = 0;",
          "}",
          "",
          "var _millisec = _Secvalue - Math.floor(_Secvalue);",
          "if (_millisec != 0) {",
          "\t//var decimalPlaces = _Secvalue.toString().split('.')[1].length;",
          "\t_millisec = _Secvalue.toString().split('.')[1];",
          "}",
          "",
          "//_millisec = _millisec.toFixed(decimalPlaces);",
          "_Secvalue = Math.floor(_Secvalue);",
          "_Secvalue = _Secvalue.toFixed(0);",
          "",
          "//msVar_uc.setText(_millisec);",
          "//secVar_uc.setText(_Secvalue);",
          "",
          "if (_millisec != 0) {",
          "\t_uc.setText(_Secvalue.concat('.', _millisec, 'S'));",
          "} else {",
          "\t_uc.setText(_Secvalue.concat('S'));",
          "}"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>
<div id="TimerButton01" data-tchmi-type="TcHmi.Controls.Beckhoff.TcHmiButton" data-tchmi-height="%ctrl%TimerValue01::Height%/ctrl%" data-tchmi-height-unit="px" data-tchmi-left="%f%%ctrl%TimerValue01::Left%/ctrl% + %ctrl%TimerValue01::Width%/ctrl%%/f%" data-tchmi-left-unit="px" data-tchmi-text="" data-tchmi-top="%ctrl%TimerValue01::Top%/ctrl%" data-tchmi-top-unit="px" data-tchmi-width="%ctrl%TimerValue01::Height%/ctrl%" data-tchmi-width-unit="px" data-tchmi-icon-width="%ctrl%TimerButton01::Width%/ctrl%" data-tchmi-icon-height="%ctrl%TimerButton01::Height%/ctrl%" data-tchmi-icon="Images/timer_symbol.ico">

<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "TimerButton01.onPressed",
    "actions": [
      {
        "objectType": "WriteToSymbol",
