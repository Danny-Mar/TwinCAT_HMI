        "sourceLines": [
          "var msVar_uc = TcHmi.Controls.get('ms_value');",
          "",
          "",
          "var _millisec = parseInt(msVar_uc.getText());",
          "",
          "_millisec = _millisec + 50;",
          "if(_millisec > 950)",
          "{",
          "\t_millisec = 0;",
          "}",
          "",
          "msVar_uc.setText(_millisec);",
          "",
          ""
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>

