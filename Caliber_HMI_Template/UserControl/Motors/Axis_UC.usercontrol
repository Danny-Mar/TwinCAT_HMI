<div data-tchmi-grid-row-index="0" data-tchmi-grid-column-index="0" id="MotorAxis_UC_ButtonToggle01_UC_6" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-height="35" data-tchmi-height-unit="px" data-tchmi-left="3" data-tchmi-left-unit="px" data-tchmi-target-user-control="UserControl/Buttons/ButtonToggle01_UC.usercontrol" data-tchmi-top="253" data-tchmi-top-unit="px" data-tchmi-width="69" data-tchmi-width-unit="px" data-tchmi-text="Home Servo" data-tchmi-state="%pp%Hmi::HOME_EN%/pp%">

<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "MotorAxis_UC_ButtonToggle01_UC_6.onPressed",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": false,
        "sourceLines": [
          "var _HomeEn = TcHmi.Symbol.readEx('%pp%Hmi::HOME_EN%/pp%');",
          "",
          "var _AxisHome = TcHmi.Symbol.readEx('%pp%Hmi::AXIS_HOME%/pp%');",
          "",
          "if (!_HomeEn)",
          "{",
          "",
          "\tif (_AxisHome) ",
          "\t{",
          "\t\tif (confirm('Axis Already Homed! Are you Sure You Want To Home Again?')) ",
          "\t\t{",
          "\t\t\tTcHmi.Symbol.writeEx('%pp%Hmi::HOME_EN%/pp%', true);",
          "\t\t}",
          "\t}",
          "\telse",
          "\t{",
          "\t\tTcHmi.Symbol.writeEx('%pp%Hmi::HOME_EN%/pp%', true);",
          "\t}",
          "",
          "}",
          "else",
          "{",
          "\tTcHmi.Symbol.writeEx('%pp%Hmi::HOME_EN%/pp%', false);\t",
          "}"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
</div>
</div>
