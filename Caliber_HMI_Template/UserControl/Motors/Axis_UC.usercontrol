<script data-tchmi-target-attribute="data-tchmi-trigger" type="application/json">
[
  {
    "event": "%pp%Hmi::ACT_VEL%/pp%",
    "actions": [
      {
        "objectType": "JavaScript",
        "active": true,
        "sourceLines": [
          "var _uc = TcHmi.Controls.get('MotorAxis_UC_Textblock11');",
          "var _velocity = TcHmi.Symbol.readEx('%pp%Hmi::ACT_VEL%/pp%');",
          "_velocity = _velocity.toFixed(1);",
          "",
          "_velocity = Math.abs(_velocity);",
          "",
          "_uc.setText(_velocity);"
        ],
        "injectContextObject": false,
        "asyncWait": true,
        "waitMode": "Synchronous"
      }
    ]
  }
]
</script>
